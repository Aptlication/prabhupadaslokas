{
  "expo": {
    "name": "Prabhupada Slokas",
    "slug": "sloka-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sloka-hub",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B3E"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0D1B3E",
      "themeColor": "#C9A84C",
      "description": "Learn, understand and memorise slokas from Srila Prabhupada's books. Learn it. Live it. Lead it.",
      "lang": "en",
      "name": "Prabhupada Slokas",
      "shortName": "Prabhupada Slokas",
      "display": "standalone",
      "orientation": "portrait",
      "scope": "/",
      "startUrl": "/"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
